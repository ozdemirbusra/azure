{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "DfExtracrTransformLoad"
		},
		"AzureDataLakeStoragesourceOlist_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStoragesourceOlist'"
		},
		"OlistSql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'OlistSql'"
		},
		"AzureDataLakeStoragesourceOlist_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sourceolist.dfs.core.windows.net/"
		},
		"OlistSql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "serverolist.database.windows.net"
		},
		"OlistSql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldbolist"
		},
		"OlistSql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladminuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "DfExtracrTransformLoad_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStoragesourceOlist_accountKey": {
						"value": "[parameters('AzureDataLakeStoragesourceOlist_accountKey')]"
					},
					"OlistSql_password": {
						"value": "[parameters('OlistSql_password')]"
					},
					"AzureDataLakeStoragesourceOlist_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStoragesourceOlist_properties_typeProperties_url')]"
					},
					"OlistSql_properties_typeProperties_server": {
						"value": "[parameters('OlistSql_properties_typeProperties_server')]"
					},
					"OlistSql_properties_typeProperties_database": {
						"value": "[parameters('OlistSql_properties_typeProperties_database')]"
					},
					"OlistSql_properties_typeProperties_userName": {
						"value": "[parameters('OlistSql_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}