{
	"name": "TargetSql",
	"properties": {
		"linkedServiceName": {
			"referenceName": "OlistSql",
			"type": "LinkedServiceReference",
			"parameters": {
				"db_schema": "stg",
				"db_tablename": {
					"value": "@concat(dataset().db_schema,'.',dataset().db_tablename)",
					"type": "Expression"
				}
			}
		},
		"parameters": {
			"db_schema": {
				"type": "String",
				"defaultValue": "stg."
			},
			"db_tablename": {
				"type": "String",
				"defaultValue": "customer"
			}
		},
		"annotations": [],
		"type": "AzureSqlTable",
		"schema": [
			{
				"name": "customer_id",
				"type": "nvarchar"
			},
			{
				"name": "customer_unique_id",
				"type": "nvarchar"
			},
			{
				"name": "customer_zip_code_prefix",
				"type": "int",
				"precision": 10
			},
			{
				"name": "customer_city",
				"type": "nvarchar"
			},
			{
				"name": "customer_state",
				"type": "nvarchar"
			},
			{
				"name": "etl_insert_date",
				"type": "datetime2",
				"scale": 0
			}
		],
		"typeProperties": {
			"schema": {
				"value": "@dataset().db_schema",
				"type": "Expression"
			},
			"table": {
				"value": "@dataset().db_tablename",
				"type": "Expression"
			}
		}
	}
}