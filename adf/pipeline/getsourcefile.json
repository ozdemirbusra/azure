{
	"name": "getsourcefile",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"additionalColumns": [
							{
								"name": "etl_date",
								"value": {
									"value": "@convertTimeZone(utcNow(),'UTC','Turkey Standard Time','yyyy-MM-dd HH:mm:ss')",
									"type": "Expression"
								}
							}
						],
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": {
								"value": "@concat(pipeline().parameters.file_name,'.',pipeline().parameters.folder_path)",
								"type": "Expression"
							},
							"wildcardFileName": "*.parquet",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "customer_id",
									"type": "UTF8"
								},
								"sink": {
									"name": "customer_id",
									"type": "nvarchar",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_unique_id",
									"type": "UTF8"
								},
								"sink": {
									"name": "customer_unique_id",
									"type": "nvarchar",
									"physicalType": "nvarchar"
								}
							},
							null,
							null
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "OlistParque",
						"type": "DatasetReference",
						"parameters": {
							"folder_path": "olist/parquet"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "TargetSql",
						"type": "DatasetReference",
						"parameters": {
							"db_schema": "stg.",
							"db_tablename": "customer"
						}
					}
				]
			},
			{
				"name": "Copy data2",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"additionalColumns": [
							{
								"name": "etl_date",
								"value": {
									"value": "@formatDateTime(utcNow(),'yyyy-MM-dd HH:mm:ss')",
									"type": "Expression"
								}
							}
						],
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": {
								"value": "@concat(pipeline().parameters.folder_path,'.',pipeline().parameters.file_name)",
								"type": "Expression"
							},
							"wildcardFileName": "*.parquet",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "OlistParque",
						"type": "DatasetReference",
						"parameters": {
							"folder_path": "olist/parquet",
							"file_name": "customers"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "TargetSql",
						"type": "DatasetReference",
						"parameters": {
							"db_schema": "stg.",
							"db_tablename": "customers"
						}
					}
				]
			}
		],
		"parameters": {
			"folder_path": {
				"type": "String"
			},
			"file_name": {
				"type": "String",
				"defaultValue": "customers"
			}
		},
		"variables": {
			"etl_date": {
				"type": "String"
			}
		},
		"annotations": []
	}
}