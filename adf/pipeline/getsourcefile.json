{
	"name": "getsourcefile",
	"properties": {
		"activities": [
			{
				"name": "source yaz",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Set variable1",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"additionalColumns": {
							"type": "Expression",
							"value": "@createArray(json(concat('{\"name\":\"etl_insert_date\",\"value\":\"', variables('etl_date'), '\"}')))"
						},
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": "olist/parquet/customers",
							"wildcardFileName": "*.parquet",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "customer_id",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_id",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_unique_id",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_unique_id",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_zip_code_prefix",
									"type": "Int32",
									"physicalType": "INT_32"
								},
								"sink": {
									"name": "customer_zip_code_prefix",
									"type": "Int32",
									"physicalType": "int"
								}
							},
							{
								"source": {
									"name": "customer_city",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_city",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_state",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_state",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "etl_insert_date",
									"type": "String"
								},
								"sink": {
									"name": "etl_insert_date",
									"type": "DateTime",
									"physicalType": "datetime2"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "OlistParque",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "TargetSql",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "Set variable1",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "etl_date25"
					}
				],
				"typeProperties": {
					"variableName": "etl_date",
					"value": {
						"value": "@formatDateTime(utcNow(),'yyyy-MM-dd HH:mm:ss')",
						"type": "Expression"
					}
				}
			}
		],
		"variables": {
			"etl_date": {
				"type": "String"
			}
		},
		"annotations": []
	}
}