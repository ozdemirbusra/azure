							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "OlistParque",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "TargetSql",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "Set variable1",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "etl_date25"
					}
				],
				"typeProperties": {
					"variableName": "pipelineReturnValue",
					"value": [
						{
							"key": "etl_date",
							"value": {
								"type": "String"
							}
						}
					],
					"setSystemVariable": true
				}
			}
		],
		"variables": {
			"etl_date": {
				"type": "String"
			}
		},
		"annotations": []
	}
