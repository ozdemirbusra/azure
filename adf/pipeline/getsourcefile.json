{
	"name": "getsourcefile",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"additionalColumns": [
							{
								"name": "etl_date",
								"value": {
									"value": "@convertTimeZone(utcNow(),'UTC','Turkey Standard Time','yyyy-MM-dd HH:mm:ss')",
									"type": "Expression"
								}
							}
						],
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": "olist/parquet/customers",
							"wildcardFileName": "*.parquet",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "customer_id",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_id",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_unique_id",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_unique_id",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_zip_code_prefix",
									"type": "Int32",
									"physicalType": "INT_32"
								},
								"sink": {
									"name": "customer_zip_code_prefix",
									"type": "Int32",
									"physicalType": "int"
								}
							},
							{
								"source": {
									"name": "customer_city",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_city",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "customer_state",
									"type": "String",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "customer_state",
									"type": "String",
									"physicalType": "nvarchar"
								}
							},
							{
								"source": {
									"name": "etl_date",
									"type": "String"
								},
								"sink": {
									"name": "etldate",
									"type": "DateTime",
									"physicalType": "datetime2"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "OlistParque",
						"type": "DatasetReference",
						"parameters": {
							"folder_path": "olist/parquet"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "TargetSql",
						"type": "DatasetReference",
						"parameters": {
							"db_schema": "stg.",
							"db_tablename": "customer"
						}
					}
				]
			}
		],
		"variables": {
			"etl_date": {
				"type": "String"
			}
		},
		"annotations": []
	}
}